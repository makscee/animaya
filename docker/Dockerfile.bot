FROM python:3.12-slim AS base

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 (needed for Claude Code CLI + Next.js dashboard)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Build Next.js dashboard
COPY dashboard/package.json dashboard/package-lock.json /dashboard/
WORKDIR /dashboard
RUN npm ci
COPY dashboard/ /dashboard/
RUN npm run build

# Python deps (install before blocking pip)
COPY pyproject.toml /app/
WORKDIR /app
RUN pip install --no-cache-dir .

# Block runtime pip install — bots must use bot.Dockerfile instead
RUN rm -f /usr/local/bin/pip /usr/local/bin/pip3 && \
    echo '#!/bin/sh' > /usr/local/bin/pip && \
    echo 'echo "ERROR: pip blocked. Edit /data/bot.Dockerfile and request a rebuild."' >> /usr/local/bin/pip && \
    echo 'exit 1' >> /usr/local/bin/pip && \
    chmod +x /usr/local/bin/pip && \
    ln -s /usr/local/bin/pip /usr/local/bin/pip3

# Copy source
COPY bot/ /app/bot/
COPY shared/ /app/shared/

# Data volume
VOLUME /data
ENV DATA_PATH=/data

EXPOSE 3000 8090

# Start script: runs both Next.js and the Python bot
COPY docker/start.sh /app/start.sh
RUN chmod +x /app/start.sh
CMD ["/app/start.sh"]
