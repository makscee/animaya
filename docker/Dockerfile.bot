# ─────────────────────────────────────────────────────────────────────
# Animaya bot container — Python engine + Next.js dashboard (Phase 13)
# ─────────────────────────────────────────────────────────────────────
# Stage 1: bun + Next.js build
#   Produces /build/dashboard/.next (+ node_modules, package.json)
# Stage 2: python:3.12-slim runtime with Node 22 + Bun CLI + built dashboard
#   Runs Python engine on 127.0.0.1:8091 (loopback) and Next.js on
#   127.0.0.1:8090 (public surface, fronted by Caddy / Voidnet edge).
# ─────────────────────────────────────────────────────────────────────

# ── Stage 1: Bun builder ─────────────────────────────────────────────
FROM oven/bun:1 AS dashboard-build
WORKDIR /build/dashboard
COPY dashboard/package.json dashboard/bun.lock ./
RUN bun install --frozen-lockfile
COPY dashboard/ ./
RUN bun run build

# ── Stage 2: runtime ─────────────────────────────────────────────────
FROM python:3.12-slim AS runtime

# Copy Bun standalone binary so `bun run start` works at runtime.
COPY --from=oven/bun:1 /usr/local/bin/bun /usr/local/bin/bun

# System deps + Node 22 (for Claude Code CLI).
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (required by bot.engine + module runtime).
RUN npm install -g @anthropic-ai/claude-code

# Python deps (install BEFORE the pip-block RUN so build succeeds).
COPY pyproject.toml /app/
WORKDIR /app
RUN pip install --no-cache-dir .

# Block runtime pip — bots must declare deps via /data/bot.Dockerfile.
RUN rm -f /usr/local/bin/pip /usr/local/bin/pip3 && \
    printf '#!/bin/sh\necho "ERROR: pip blocked. Edit /data/bot.Dockerfile and request a rebuild."\nexit 1\n' > /usr/local/bin/pip && \
    chmod +x /usr/local/bin/pip && \
    ln -s /usr/local/bin/pip /usr/local/bin/pip3

# Python source.
COPY bot/ /app/bot/

# Dashboard build artifacts — full tree + .next so `bun run start` works.
COPY --from=dashboard-build /build/dashboard /app/dashboard

# Data volume + env defaults.
VOLUME /data
ENV DATA_PATH=/data

# 8090 = Next.js public surface (fronted by Caddy). 8091 is loopback only.
EXPOSE 8090

# bot.main supervises the Python engine AND spawns `bun run start`
# for the Next.js dashboard in-process.
CMD ["python", "-m", "bot"]
