FROM python:3.12-slim AS base

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 (needed for Claude Code CLI)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Python deps (install before blocking pip)
COPY pyproject.toml /app/
WORKDIR /app
RUN pip install --no-cache-dir .

# Block runtime pip install — bots must use bot.Dockerfile instead
RUN rm -f /usr/local/bin/pip /usr/local/bin/pip3 && \
    echo '#!/bin/sh' > /usr/local/bin/pip && \
    echo 'echo "ERROR: pip blocked. Edit /data/bot.Dockerfile and request a rebuild."' >> /usr/local/bin/pip && \
    echo 'exit 1' >> /usr/local/bin/pip && \
    chmod +x /usr/local/bin/pip && \
    ln -s /usr/local/bin/pip /usr/local/bin/pip3

# Copy source
COPY bot/ /app/bot/
COPY shared/ /app/shared/

# Apply per-bot customizations if bot.Dockerfile exists
# (platform rebuilds with: docker build -f data/bot.Dockerfile ...)
ONBUILD COPY bot.Dockerfile /tmp/bot.Dockerfile
ONBUILD RUN if [ -f /tmp/bot.Dockerfile ]; then \
    grep '^RUN ' /tmp/bot.Dockerfile | while read -r line; do \
        cmd=$(echo "$line" | sed 's/^RUN //'); \
        eval "$cmd"; \
    done; fi

# Data volume
VOLUME /data
ENV DATA_PATH=/data

EXPOSE 8090

CMD ["python", "-m", "bot"]
