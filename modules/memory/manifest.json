{
  "manifest_version": 1,
  "name": "memory",
  "version": "1.0.0",
  "system_prompt_path": "prompt.md",
  "owned_paths": [],
  "scripts": {
    "install": "install.sh",
    "uninstall": "uninstall.sh"
  },
  "depends": ["identity"],
  "config_schema": {
    "type": "object",
    "properties": {
      "consolidation_model": {
        "type": "string",
        "default": "claude-haiku-4-5"
      },
      "core_max_lines": {
        "type": "integer",
        "default": 150,
        "minimum": 20
      },
      "consolidation_every_n_turns": {
        "type": "integer",
        "default": 10,
        "minimum": 1
      }
    }
  }
}
